{
  "name": "pr-remaps-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "format": "prettier --write \"*.html\" \"src/**/*.{js,jsx,css}\"",
    "format:check": "prettier --check \"*.html\" \"src/**/*.{js,jsx,css}\"",
    "audit": "npm audit"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^2.1.1",
    "prettier": "^3.2.5",
    "sharp": "^0.35.1",
    "terser": "^5.46.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
